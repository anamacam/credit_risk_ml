# =========================
# MLflow (Profesional)
# =========================

# Ignorar la base de datos de experimentos (SQLite)
experiments/*.db

# Ignorar las carpetas de artefactos generadas por MLflow (suelen ser números: 0, 1, 2...)
experiments/[0-9]*/

# Ignorar mlruns si por error se genera
mlruns/

